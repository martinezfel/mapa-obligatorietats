true}, {"pregunta": "Està garantit l'accés als serveis funeraris al municipi?", "llei_nom": "Llei 2/1997, de 3 d'abril, sobre serveis funeraris", "article": "art. 1", "explicacio": "Els serveis funeraris són un servei essencial d'interès general que l'ajuntament ha de garantir a tota la col·lectivitat local.", "llindar_label": "Tots els municipis", "pob_min": null, "pob_min_strict": true, "pob_max": null, "pob_max_strict": true}, {"pregunta": "Se sap qui presta els serveis funeraris i sota quin règim d'autorització?", "llei_nom": "Llei 2/1997, de 3 d'abril, sobre serveis funeraris", "article": "art. 1", "explicacio": "Els serveis funeraris poden ser prestats per l'Administració, empreses públiques o empreses privades, sempre sotmesos a control, policia i autorització.", "llindar_label": "Tots els municipis", "pob_min": null, "pob_min_strict": true, "pob_max": null, "pob_max_strict": true}], "data_actualitzacio": "2026-07-01"}, {"id": "recollida-residus", "nom": "Recollida de residus", "bloc": "obligatori", "ambit": "Urbanisme, via pública i medi ambient", "tram_base": null, "font_star": false, "estat": "pendent", "resum": null, "competencia": null, "normativa_mare": [], "checklist": [], "data_actualitzacio": null}, {"id": "neteja-viaria", "nom": "Neteja viària", "bloc": "obligatori", "ambit": "Urbanisme, via pública i medi ambient", "tram_base": null, "font_star": false, "estat": "pendent", "resum": null, "competencia": null, "normativa_mare": [], "checklist": [], "data_actualitzacio": null}, {"id": "abastament-aigua", "nom": "Abastament domiciliari d'aigua potable", "bloc": "obligatori", "ambit": "Urbanisme, via pública i medi ambient", "tram_base": null, "font_star": false, "estat": "pendent", "resum": null, "competencia": null, "normativa_mare": [], "checklist": [], "data_actualitzacio": null}, {"id": "clavegueram", "nom": "Clavegueram / evacuació d'aigües residuals", "bloc": "obligatori", "ambit": "Urbanisme, via pública i medi ambient", "tram_base": null, "font